generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── 用户（网络模式专用，单机模式有哨兵行 id=0）──────
model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  displayName  String
  role         String       @default("parent") // parent | child
  createdAt    String
  updatedAt    String
  tasks        Task[]
  checkins     CheckIn[]
  redemptions  Redemption[]
  products     Product[]
  exerciseTypes ExerciseType[]
  exercises    Exercise[]
  settings     Setting[]
}

// ── 任务 ──────────────────────────────────────────
model Task {
  id            Int        @id @default(autoincrement())
  name          String
  subject       String
  emoji         String     @default("📚")
  estimatedMin  Int        @default(0)
  deadlineTime  String?
  startDate     String?                   // 任务生效日期 YYYY-MM-DD（一次性任务用）
  repeatType    String     @default("once") // once | daily | weekly
  repeatDays    String     @default("[]")   // JSON array [1,3,5]
  sortOrder     Int        @default(0)
  isActive      Int        @default(1)      // 1=active, 0=deleted
  points        Int        @default(3)       // 积分上限
  createdAt     String
  updatedAt     String
  userId        Int        @default(0)
  user          User?      @relation(fields: [userId], references: [id])
  checkins      CheckIn[]
}

// ── 打卡记录 ──────────────────────────────────────
model CheckIn {
  id           Int     @id @default(autoincrement())
  taskId       Int
  task         Task    @relation(fields: [taskId], references: [id])
  date         String  // YYYY-MM-DD
  completedAt  String  // ISO8601
  quality      Int?    // 1-3 stars
  photoUrl     String?
  note         String?
  isMakeup     Int     @default(0)
  userId       Int     @default(0)
  user         User?   @relation(fields: [userId], references: [id])

  @@unique([taskId, date])
}

// ── 积分兑换 ──────────────────────────────────────
model Redemption {
  id          Int      @id @default(autoincrement())
  name        String   // 兑换内容
  points      Int      // 消耗积分
  date        String   // YYYY-MM-DD
  photoUrl    String?
  createdAt   String
  productId   Int?     // 关联商品
  status      String   @default("pending") // pending | approved | rejected
  appliedAt   String?  // 申请时间
  approvedAt  String?  // 审批时间
  userId      Int      @default(0)
  user        User?    @relation(fields: [userId], references: [id])
}

// ── 兑换商品 ──────────────────────────────────────
model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  points      Int
  photoUrl    String?
  isActive    Int     @default(1)
  sortOrder   Int     @default(0)
  createdAt   String
  userId      Int     @default(0)
  user        User?   @relation(fields: [userId], references: [id])
}

// ── 运动类型 ──────────────────────────────────────
model ExerciseType {
  id          Int         @id @default(autoincrement())
  name        String
  emoji       String      @default("🏃")
  unit        String      @default("次")
  isPreset    Int         @default(1)
  isActive    Int         @default(1)
  sortOrder   Int         @default(0)
  createdAt   String
  userId      Int         @default(0)
  user        User?       @relation(fields: [userId], references: [id])
  exercises   Exercise[]
}

// ── 运动记录 ──────────────────────────────────────
model Exercise {
  id              Int          @id @default(autoincrement())
  exerciseTypeId  Int
  exerciseType    ExerciseType @relation(fields: [exerciseTypeId], references: [id])
  date            String
  completedAt     String
  quality         Int?
  sets            String?
  note            String?
  isMakeup        Int          @default(0)
  createdAt       String
  userId          Int          @default(0)
  user            User?        @relation(fields: [userId], references: [id])
}

// ── 设置 ──────────────────────────────────────────
model Setting {
  key    String @id
  value  String
  userId Int    @default(0)
  user   User?  @relation(fields: [userId], references: [id])
}